{
  "name": "omnifocus-mcp-pro",
  "type": "module",
  "version": "2.0.1",
  "description": "Pro OmniFocus MCP server — 19 tools, unified query engine, MCP Resources, GTD workflow support, custom perspectives, and text search. macOS only.",
  "main": "dist/server.js",
  "bin": {
    "omnifocus-mcp-pro": "./cli.cjs"
  },
  "files": [
    "dist/",
    "cli.cjs"
  ],
  "scripts": {
    "build": "tsc && npm run copy-files && chmod 755 dist/server.js",
    "copy-files": "mkdir -p dist/utils/omnifocusScripts && cp src/utils/omnifocusScripts/*.js dist/utils/omnifocusScripts/",
    "start": "node dist/server.js",
    "dev": "tsc -w",
    "prepublishOnly": "npm run build",
    "test": "echo \"Test passed - manual testing required with OmniFocus\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/darrenyao/omnifocus-mcp-enhanced.git"
  },
  "homepage": "https://github.com/darrenyao/omnifocus-mcp-enhanced",
  "keywords": [
    "omnifocus",
    "mcp",
    "model-context-protocol",
    "claude",
    "ai-agent",
    "task-management",
    "gtd",
    "productivity",
    "macos",
    "perspective",
    "omnifocus-automation"
  ],
  "author": {
    "name": "darrenyao"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin"
  ],
  "license": "MIT"
}
